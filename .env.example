# Copy to .env for local dev. Never commit the real .env.
# In production these are set as Fly secrets (fly secrets set KEY=value).

# ─── Current (Phase 0) ──────────────────────────────────────────────────────

# Port the server listens on. Fly sets this automatically in prod.
PORT=3000

# Directory where polls.json lives. Defaults to the app directory if unset.
DATA_DIR=

# Shared admin password (legacy single-owner auth, removed in Phase 1).
# Must be set to a real secret in prod — the code falls back to the
# insecure default "brady" if this is missing.
ADMIN_PASSWORD=

# ─── Phase 1/2 — accounts, sessions, Postgres ──────────────────────────────

# Postgres connection string (set automatically by `fly postgres attach`).
DATABASE_URL=

# Secret used to sign session JWTs. Generate with: openssl rand -hex 32
JWT_SECRET=

# ─── Phase 1 — magic-link email ────────────────────────────────────────────

# Resend API key, used to send magic-link login emails and notifications.
RESEND_API_KEY=

# ─── Phase 3 — billing ──────────────────────────────────────────────────────

# Stripe secret key for Checkout + billing portal.
STRIPE_SECRET_KEY=

# Stripe webhook signing secret, used to verify webhook payloads.
STRIPE_WEBHOOK_SECRET=
